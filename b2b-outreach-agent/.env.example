# Copy this file to .env before running anything.

# SQLite for local/demo use. To switch to Postgres, see README "Switching to Postgres".
DATABASE_URL="file:./dev.db"

# Any long random string works for local/demo use.
JWT_SECRET="change-this-to-a-long-random-string"

# Access token lifetime
JWT_EXPIRES_IN="12h"

PORT=4000

# Milestone 2+: Gemini embeddings (get a key at https://aistudio.google.com)
GEMINI_API_KEY=your-gemini-api-key-here

# Chroma vector DB — Milestone 2+
# Default assumes docker-compose up -d from the project root.
CHROMA_URL=http://localhost:8000

# Email sending — Milestone 4
# "simulated" (default): logs to console, no real emails. Great for demos.
# "resend": calls the Resend API (requires RESEND_API_KEY + verified domain).
EMAIL_PROVIDER=simulated
RESEND_API_KEY=
EMAIL_FROM=outreach@meridianrealty.test
